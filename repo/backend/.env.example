APP_ENV=development
PORT=8080
JWT_SECRET=dev-secret-change-me
JWT_IDLE_MINUTES=30
JWT_ABSOLUTE_HOURS=12
ADMIN_ALLOWLIST=127.0.0.1/32,::1/128
TRUSTED_PROXIES=
ALLOW_INSECURE_HTTP_CIDRS=127.0.0.1/32,::1/128
# For Docker-hosted integration tests, add the Docker bridge CIDR to allow CLI-driven traffic:
# ALLOW_INSECURE_HTTP_CIDRS=127.0.0.1/32,::1/128,172.16.0.0/12
# Local-only testing shortcut (do not use in production):
# ADMIN_ALLOWLIST=127.0.0.1/32,::1/128,0.0.0.0/0
# ALLOW_INSECURE_HTTP_CIDRS=127.0.0.1/32,::1/128,0.0.0.0/0
AES256_KEY=0123456789abcdef0123456789abcdef
ATTACHMENT_DIR=./data/attachments
ATTACHMENT_SIGNING_SECRET=dev-secret-change-me
STORE_BACKEND=postgres
DB_HOST=db
DB_PORT=5432
DB_USER=fleetlease
DB_NAME=fleetlease
DB_PASSWORD=fleetlease
DB_SSL_MODE=disable
# Optional explicit DSN override:
# DATABASE_URL=postgres://fleetlease:fleetlease@db:5432/fleetlease?sslmode=disable
BACKUP_RETENTION_DAYS=30
ATTACHMENT_RETENTION_DAYS=365
LEDGER_RETENTION_YEARS=7
NOTIFICATION_RETRY_MAX=3
NOTIFICATION_RETRY_BACKOFF_SECONDS=30
REQUIRE_ADMIN_MFA=true
TLS_CERT_FILE=
TLS_KEY_FILE=
RETENTION_PURGE_INTERVAL_MINUTES=1440
